# Prisma
DATABASE_URL="file:./dev.db"

# Data provider: jquants | edinet | csv | composite
DATA_PROVIDER="csv"

# J-Quants V2 API (2025-12-22 以降、新規ユーザーは V2 のみ)
JQUANTS_API_KEY=""
# V1 legacy (V2 では未使用、後方互換のためのみ残存):
# JQUANTS_MAIL_ADDRESS=""
# JQUANTS_PASSWORD=""

# Server
PORT=8902
# Comma-separated allowed origins for CORS (leave empty to allow all)
ALLOWED_ORIGINS=""
NODE_ENV=development
TZ=Asia/Tokyo
# Optional: set a secret string to protect /api/admin/* routes (leave empty to allow all in dev)
ADMIN_TOKEN=""

# Screening defaults
MARKET_CAP_MAX_YEN=50000000000
NET_CASH_RATIO_MIN=0.3
MVP_STOCK_LIMIT=30
