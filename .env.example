# Prisma
DATABASE_URL="file:./dev.db"

# Data provider: jquants | edinet | csv | composite
DATA_PROVIDER="csv"

# J-Quants (Phase 1 で使用)
JQUANTS_MAIL_ADDRESS=""
JQUANTS_PASSWORD=""
JQUANTS_REFRESH_TOKEN=""

# Server
PORT=8902
NODE_ENV=development
TZ=Asia/Tokyo

# Screening defaults
MARKET_CAP_MAX_YEN=50000000000
NET_CASH_RATIO_MIN=0.3
MVP_STOCK_LIMIT=30
